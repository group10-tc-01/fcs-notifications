{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "KafkaSettings": {
    "BootstrapServers": "localhost:9092",
    "GroupId": "fcs-notifications-consumer-group",
    "ConsumerTimeoutMs": 100,
    "Topics": {
      "EmailNotification": "email-notification-requested"
    }
  },
  "Resend": {
    "ApiKey": ""
  },
  "ResendTemplates": {
    "DonorWelcomeTemplateId": "",
    "DonationCreatedTemplateId": "",
    "DonationProcessedTemplateId": ""
  },
  "Observability": {
    "ServiceName": "Fcs.Notifications",
    "EnableOtlpExporter": false,
    "OtlpEndpoint": "",
    "OtlpAuthHeader": ""
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ]
  }
}
